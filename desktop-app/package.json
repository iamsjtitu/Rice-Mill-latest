{
  "name": "mill-entry-system",
  "version": "1.0.0",
  "description": "Mill Entry Management System - Windows Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:frontend && electron-builder --win",
    "build:frontend": "cd ../frontend && npm run build && cp -r build ../desktop-app/frontend-build",
    "build:win": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "author": "Mill Entry System",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "build": {
    "appId": "com.millentry.desktop",
    "productName": "Mill Entry System",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "frontend-build/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "assets",
        "to": "assets",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mill Entry System"
    },
    "portable": {
      "artifactName": "MillEntrySystem-Portable.exe"
    }
  }
}
