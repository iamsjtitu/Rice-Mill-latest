{
  "name": "mill-entry-system",
  "version": "1.0.0",
  "description": "Mill Entry Management System - Windows Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "npx electron .",
    "setup": "node setup-desktop.js",
    "build": "node setup-desktop.js && npx electron-builder --win",
    "build:win": "npx electron-builder --win --x64",
    "pack": "npx electron-builder --dir"
  },
  "author": "Mill Entry System",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.13.0"
  },
  "build": {
    "appId": "com.millentry.desktop",
    "productName": "Mill Entry System",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "."
    },
    "files": [
      "main.js",
      "preload.js",
      "frontend-build/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mill Entry System",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    },
    "portable": {
      "artifactName": "MillEntrySystem-Portable.exe"
    }
  }
}
