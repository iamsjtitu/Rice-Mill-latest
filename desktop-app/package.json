{
  "name": "mill-entry-system",
  "version": "104.37.8",
  "description": "Mill Entry Management System - Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "npx electron .",
    "setup": "node setup-desktop.js",
    "fetch-public-key": "node scripts/fetch-public-key.js",
    "build": "node setup-desktop.js && node scripts/fetch-public-key.js && npx electron-builder --win --publish never",
    "build:win": "node scripts/fetch-public-key.js && npx electron-builder --win --x64 --publish never",
    "build:mac": "node scripts/fetch-public-key.js && npx electron-builder --mac --arm64 --publish never",
    "build:mac-dmg": "npx electron-builder --mac dmg --arm64 --publish never",
    "build:mac-pkg": "npx electron-builder --mac pkg --arm64 --publish never",
    "build:mac-all": "npx electron-builder --mac dmg pkg --arm64 --publish never",
    "pack": "npx electron-builder --dir --publish never"
  },
  "author": "Mill Entry System",
  "license": "MIT",
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "24.9.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.7.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "electron-updater": "^6.1.7",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.3.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.13.0",
    "serialport": "^12.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.20.0"
  },
  "build": {
    "appId": "com.millentry.desktop",
    "productName": "Mill Entry System",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "."
    },
    "files": [
      "main.js",
      "preload.js",
      "serial-handler.js",
      "sqlite-database.js",
      "license-manager.js",
      "cloudflared-manager.js",
      "mlic-import.js",
      "routes/**/*",
      "utils/**/*",
      "shared/**/*",
      "fonts/**/*",
      "frontend-build/**/*",
      "activation-ui/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "extraResources": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg.exe",
          "to": "ffmpeg.exe"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "pkg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "icon.icns",
      "category": "public.app-category.business",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg",
          "to": "ffmpeg"
        }
      ]
    },
    "dmg": {
      "title": "Mill Entry System",
      "artifactName": "MillEntrySystem-${version}-mac.dmg",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "pkg": {
      "artifactName": "MillEntrySystem-${version}-mac.pkg"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "iamsjtitu",
        "repo": "Rice-Mill-latest",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mill Entry System",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "artifactName": "Mill-Entry-System-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "MillEntrySystem-Portable.exe"
    }
  }
}
