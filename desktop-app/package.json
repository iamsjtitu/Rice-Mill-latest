{
  "name": "mill-entry-system",
  "version": "42.0.0",
  "description": "Mill Entry Management System - Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "npx electron .",
    "setup": "node setup-desktop.js",
    "build": "node setup-desktop.js && npx electron-builder --win",
    "build:win": "npx electron-builder --win --x64",
    "build:mac": "npx electron-builder --mac --arm64",
    "build:mac-dmg": "npx electron-builder --mac dmg --arm64",
    "build:mac-pkg": "npx electron-builder --mac pkg --arm64",
    "build:mac-all": "npx electron-builder --mac dmg pkg --arm64",
    "pack": "npx electron-builder --dir"
  },
  "author": "Mill Entry System",
  "license": "MIT",
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "24.9.1"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "electron-updater": "^6.1.7",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.13.0",
    "uuid": "^9.0.0"
  },
  "build": {
    "appId": "com.millentry.desktop",
    "productName": "Mill Entry System",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "."
    },
    "files": [
      "main.js",
      "preload.js",
      "routes/**/*",
      "utils/**/*",
      "shared/**/*",
      "frontend-build/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "pkg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "icon.icns",
      "category": "public.app-category.business",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Mill Entry System",
      "artifactName": "MillEntrySystem-${version}-mac.dmg",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "pkg": {
      "artifactName": "MillEntrySystem-${version}-mac.pkg"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "iamsjtitu",
        "repo": "Rice-Mill-latest",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mill Entry System",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    },
    "portable": {
      "artifactName": "MillEntrySystem-Portable.exe"
    }
  }
}